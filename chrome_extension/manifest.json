{
  "manifest_version": 3,
  "name": "HEALTHINSIGHT Anywhere",
  "version": "1.0.0",
  "description": "Chat with HEALTHINSIGHT over your DuckDB from any tab.",
  "action": {
    "default_title": "HEALTHINSIGHT",
    "default_popup": "popup.html"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "http://localhost:8787/*",
    "https://localhost:8787/*"
  ]
}


